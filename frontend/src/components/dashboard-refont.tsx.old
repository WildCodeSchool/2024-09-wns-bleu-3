                    </TabsTrigger>
                    <TabsTrigger
                      value="favorites"
                      className="data-[state=active]:bg-white/90 data-[state=active]:shadow-lg data-[state=active]:backdrop-blur-sm"
                    >
                      Favorites
                    </TabsTrigger>
                  </TabsList>

                  <TabsContent value="all" className="space-y-4">
                    {filteredScans.length > 0 ? (
                      filteredScans.map((scan) => (
                        <Link href={`/dashboard/${scan.id}`} key={scan.id}>
                          <Card className="border border-white/40 hover:border-white/60 hover:shadow-xl transition-all duration-300 cursor-pointer group bg-white/40 backdrop-blur-sm relative overflow-hidden">
                            <div className="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <CardContent className="p-6 relative z-10">
                              <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                <div className="flex items-center gap-4">
                                  <div
                                    className={`flex h-14 w-14 items-center justify-center rounded-3xl shadow-xl transition-all duration-300 group-hover:scale-110
                                    ${scan.status === 200
                                        ? "bg-emerald-600/80 shadow-emerald-600/25"
                                        : scan.status === 404
                                          ? "bg-amber-600/80 shadow-amber-600/25"
                                          : "bg-red-600/80 shadow-red-600/25"
                                      }`}
                                  >
                                    {scan.status === 200 ? (
                                      <CheckCircle className="h-7 w-7 text-white" />
                                    ) : scan.status === 404 ? (
                                      <AlertTriangle className="h-7 w-7 text-white" />
                                    ) : (
                                      <XCircle className="h-7 w-7 text-white" />
                                    )}
                                  </div>
                                  <div>
                                    <h3 className="font-bold text-slate-900 group-hover:text-slate-700 transition-colors text-lg">
                                      {scan.title}
                                    </h3>
                                    <p className="text-sm text-slate-600 font-medium">{scan.url}</p>
                                  </div>
                                </div>
                                <div className="flex flex-wrap items-center gap-4 ml-18 md:ml-0">
                                  <div className="flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-sm rounded-2xl border border-white/40 shadow-lg">
                                    <Clock className="h-4 w-4 text-slate-500" />
                                    <span className="text-sm font-bold text-slate-700">{scan.responseTime}ms</span>
                                  </div>
                                  <div className="flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-sm rounded-2xl border border-white/40 shadow-lg">
                                    <Activity className="h-4 w-4 text-slate-500" />
                                    <span className="text-sm font-bold text-slate-700">{scan.uptime}</span>
                                  </div>
                                  <Badge
                                    className={`shadow-lg border-0 font-bold px-4 py-2 rounded-2xl text-white
                                      ${scan.status === 200
                                        ? "bg-emerald-600"
                                        : scan.status === 404
                                          ? "bg-amber-600"
                                          : "bg-red-600"
                                      }
                                    `}
                                  >
                                    {scan.status}
                                  </Badge>
                                  <span className="text-sm text-slate-500 font-medium">{scan.lastChecked}</span>
                                  <Badge className="bg-slate-700 text-white border-0 shadow-lg font-bold px-4 py-2 rounded-2xl">
                                    {scan.tag}
                                  </Badge>
                                  <ArrowUpRight className="h-5 w-5 text-slate-400 group-hover:text-slate-600 transition-colors" />
                                </div>
                              </div>
                            </CardContent>
                          </Card>
                        </Link>
                      ))
                    ) : (
                      <div className="text-center py-16">
                        <div className="h-20 w-20 bg-slate-200/80 rounded-3xl flex items-center justify-center mx-auto mb-6 backdrop-blur-sm shadow-xl">
                          <Monitor className="h-10 w-10 text-slate-500" />
                        </div>
                        <p className="text-slate-500 mb-6 font-medium text-lg">
                          No monitors found matching your criteria.
                        </p>
                        <Button className="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 shadow-xl shadow-blue-500/25 backdrop-blur-sm font-medium">
                          <Plus className="mr-2 h-4 w-4" /> Add New Monitor
                        </Button>
                      </div>
                    )}
                  </TabsContent>

                  <TabsContent value="active" className="space-y-4">
                    {filteredScans
                      .filter((scan) => scan.status === 200)
                      .map((scan) => (
                        <Link href={`/dashboard/${scan.id}`} key={scan.id}>
                          <Card className="border border-white/40 hover:border-white/60 hover:shadow-xl transition-all duration-300 cursor-pointer group bg-white/40 backdrop-blur-sm relative overflow-hidden">
                            <div className="absolute inset-0 bg-emerald-50/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <CardContent className="p-6 relative z-10">
                              <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                <div className="flex items-center gap-4">
                                  <div className="flex h-14 w-14 items-center justify-center rounded-3xl bg-emerald-600/80 shadow-xl shadow-emerald-600/25 transition-all duration-300 group-hover:scale-110">
                                    <CheckCircle className="h-7 w-7 text-white" />
                                  </div>
                                  <div>
                                    <h3 className="font-bold text-slate-900 group-hover:text-emerald-700 transition-colors text-lg">
                                      {scan.title}
                                    </h3>
                                    <p className="text-sm text-slate-600 font-medium">{scan.url}</p>
                                  </div>
                                </div>
                                <div className="flex flex-wrap items-center gap-4 ml-18 md:ml-0">
                                  <div className="flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-sm rounded-2xl border border-white/40 shadow-lg">
                                    <Clock className="h-4 w-4 text-slate-500" />
                                    <span className="text-sm font-bold text-slate-700">{scan.responseTime}ms</span>
                                  </div>
                                  <div className="flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-sm rounded-2xl border border-white/40 shadow-lg">
                                    <Activity className="h-4 w-4 text-slate-500" />
                                    <span className="text-sm font-bold text-slate-700">{scan.uptime}</span>
                                  </div>
                                  <Badge className="bg-emerald-600 text-white border-0 shadow-lg font-bold px-4 py-2 rounded-2xl">
                                    {scan.status}
                                  </Badge>
                                  <span className="text-sm text-slate-500 font-medium">{scan.lastChecked}</span>
                                  <Badge className="bg-slate-700 text-white border-0 shadow-lg font-bold px-4 py-2 rounded-2xl">
                                    {scan.tag}
                                  </Badge>
                                  <ArrowUpRight className="h-5 w-5 text-slate-400 group-hover:text-emerald-600 transition-colors" />
                                </div>
                              </div>
                            </CardContent>
                          </Card>
                        </Link>
                      ))}
                  </TabsContent>

                  <TabsContent value="issues" className="space-y-4">
                    {filteredScans
                      .filter((scan) => scan.status !== 200)
                      .map((scan) => (
                        <Link href={`/dashboard/${scan.id}`} key={scan.id}>
                          <Card className="border border-white/40 hover:border-white/60 hover:shadow-xl transition-all duration-300 cursor-pointer group bg-white/40 backdrop-blur-sm relative overflow-hidden">
                            <div className="absolute inset-0 bg-red-50/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <CardContent className="p-6 relative z-10">
                              <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                <div className="flex items-center gap-4">
                                  <div
                                    className={`flex h-14 w-14 items-center justify-center rounded-3xl shadow-xl transition-all duration-300 group-hover:scale-110
                                    ${scan.status === 404
                                        ? "bg-amber-600/80 shadow-amber-600/25"
                                        : "bg-red-600/80 shadow-red-600/25"
                                      }`}
                                  >
                                    {scan.status === 404 ? (
                                      <AlertTriangle className="h-7 w-7 text-white" />
                                    ) : (
                                      <XCircle className="h-7 w-7 text-white" />
                                    )}
                                  </div>
                                  <div>
                                    <h3 className="font-bold text-slate-900 group-hover:text-red-700 transition-colors text-lg">
                                      {scan.title}
                                    </h3>
                                    <p className="text-sm text-slate-600 font-medium">{scan.url}</p>
                                  </div>
                                </div>
                                <div className="flex flex-wrap items-center gap-4 ml-18 md:ml-0">
                                  <div className="flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-sm rounded-2xl border border-white/40 shadow-lg">
                                    <Clock className="h-4 w-4 text-slate-500" />
                                    <span className="text-sm font-bold text-slate-700">{scan.responseTime}ms</span>
                                  </div>
                                  <div className="flex items-center gap-2 px-4 py-2 bg-white/60 backdrop-blur-sm rounded-2xl border border-white/40 shadow-lg">
                                    <Activity className="h-4 w-4 text-slate-500" />
                                    <span className="text-sm font-bold text-slate-700">{scan.uptime}</span>
                                  </div>
                                  <Badge
                                    className={`shadow-lg border-0 font-bold px-4 py-2 rounded-2xl text-white
                                      ${scan.status === 404 ? "bg-amber-600" : "bg-red-600"}
                                    `}
                                  >
                                    {scan.status}
                                  </Badge>
                                  <span className="text-sm text-slate-500 font-medium">{scan.lastChecked}</span>
                                  <Badge className="bg-slate-700 text-white border-0 shadow-lg font-bold px-4 py-2 rounded-2xl">
                                    {scan.tag}
                                  </Badge>
                                  <ArrowUpRight className="h-5 w-5 text-slate-400 group-hover:text-red-600 transition-colors" />
                                </div>
                              </div>
                            </CardContent>
                          </Card>
                        </Link>
                      ))}
                  </TabsContent>

                  <TabsContent value="favorites">
                    <div className="text-center py-16">
                      <div className="h-20 w-20 bg-slate-200/80 rounded-3xl flex items-center justify-center mx-auto mb-6 backdrop-blur-sm shadow-xl">
                        <Sparkles className="h-10 w-10 text-slate-500" />
                      </div>
                      <p className="text-slate-500 mb-4 font-medium text-lg">
                        You haven't marked any monitors as favorites yet.
                      </p>
                      <p className="text-sm text-slate-400 font-medium">
                        Star your most important monitors to see them here.
                      </p>
                    </div>
                  </TabsContent>
                </Tabs>
              </CardContent>
              <div className="absolute bottom-0 right-0 w-40 h-40 bg-slate-900/5 rounded-full blur-3xl"></div>
            </Card>
          </div>
        </main>
      </div>
    </SidebarProvider>
  )
}
